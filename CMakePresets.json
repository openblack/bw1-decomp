{
  "version": 9,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 30,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "release",
      "displayName": "Byte-exact recompilation of vanilla.",
      "description": "Release configuration with Ninja that will generate md5sum=174b1a64e74b2321f3c38ccc8a511e78.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/cmake-build-presets/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "relwithdebinfo",
      "displayName": "Offset-exact with Debug info.",
      "description": "RelWithDebInfo configuration with Ninja that will have some debug info.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/cmake-build-presets/welwithdebinfo",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "objdiff",
      "displayName": "Configuration for running objdiff.",
      "description": "Release configuration with Ninja that will generate md5sum=174b1a64e74b2321f3c38ccc8a511e78.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/cmake-build-presets/objdiff",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "OBJDIFF": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "relwithdebinfo",
      "configurePreset": "relwithdebinfo"
    },
    {
      "name": "objdiff",
      "configurePreset": "objdiff"
    }
  ],
  "workflowPresets": [
    {
      "name": "release",
      "steps": [
        {
          "type": "configure",
          "name": "release"
        },
        {
          "type": "build",
          "name": "release"
        }
      ]
    },
    {
      "name": "relwithdebinfo",
      "steps": [
        {
          "type": "configure",
          "name": "relwithdebinfo"
        },
        {
          "type": "build",
          "name": "relwithdebinfo"
        }
      ]
    },
    {
      "name": "objdiff",
      "steps": [
        {
          "type": "configure",
          "name": "objdiff"
        },
        {
          "type": "build",
          "name": "objdiff"
        }
      ]
    }
  ]
}
